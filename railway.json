{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT",
    "restartPolicyMaxRetries": 5,
    "restartPolicyMaxRetryDelay": 300
  },
  "plugins": [
    "postgresql",
    "redis"
  ],
  "variables": {
    "DEBUG": "false",
    "APP_NAME": "Carolina Reminder"
  }
}
